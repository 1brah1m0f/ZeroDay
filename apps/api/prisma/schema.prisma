generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NOTE: SQLite does not support enums, using String fields instead ────────

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String
  displayName String
  avatarUrl   String?
  bio         String?
  role        String   @default("USER")     // USER | MODERATOR | ADMIN
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  listings       Listing[]
  groups         GroupMember[]
  ownedGroups    Group[]         @relation("GroupOwner")
  forumTopics    ForumTopic[]
  forumComments  ForumComment[]
  userBadges     UserBadge[]
  experiences    Experience[]
  sentMessages   ChatMessage[]
  conversations  ConversationParticipant[]
  givenVotes     ForumVote[]
  applications   Application[]  @relation("Applicant")
  receivedApps   Application[]  @relation("ListingOwner")
  savedListings  SavedListing[]

  @@map("users")
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("OTHER")    // VOLUNTEER | EDUCATION | JOBS | SERVICES | EVENTS | OTHER
  status      String   @default("ACTIVE")   // ACTIVE | CLOSED | DRAFT
  images      String   @default("[]")
  tags        String   @default("[]")
  viewCount   Int      @default(0)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
  savedBy      SavedListing[]

  @@index([category, status])
  @@index([authorId])
  @@map("listings")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  privacy     String   @default("PUBLIC")   // PUBLIC | PRIVATE | INVITE_ONLY
  coverUrl    String?
  avatarUrl   String?
  tags        String   @default("[]")
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  members     GroupMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("groups")
}

model GroupMember {
  userId   String
  groupId  String
  role     String   @default("MEMBER")    // OWNER | ADMIN | MEMBER
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("group_members")
}

model ForumTopic {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  body         String
  tags         String         @default("[]")
  isPinned     Boolean        @default(false)
  isLocked     Boolean        @default(false)
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     ForumComment[]
  votes        ForumVote[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tags])
  @@index([authorId])
  @@map("forum_topics")
}

model ForumComment {
  id        String         @id @default(cuid())
  body      String
  topicId   String
  topic     ForumTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ForumComment?  @relation("Replies", fields: [parentId], references: [id])
  replies   ForumComment[] @relation("Replies")
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes     ForumVote[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("forum_comments")
}

model ForumVote {
  id        String        @id @default(cuid())
  value     Int           // 1 or -1
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId   String?
  topic     ForumTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  commentId String?
  comment   ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, topicId])
  @@unique([userId, commentId])
  @@map("forum_votes")
}

model Conversation {
  id           String                   @id @default(cuid())
  participants ConversationParticipant[]
  messages     ChatMessage[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@map("conversations")
}

model ConversationParticipant {
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@id([userId, conversationId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String       @id @default(cuid())
  body           String
  isRead         Boolean      @default(false)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String
  tier        String      @default("BRONZE")  // BRONZE | SILVER | GOLD | PLATINUM
  userBadges  UserBadge[]
  createdAt   DateTime    @default(now())

  @@map("badges")
}

model UserBadge {
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@id([userId, badgeId])
  @@map("user_badges")
}

model Experience {
  id           String    @id @default(cuid())
  type         String    @default("WORK")  // WORK | EDUCATION | VOLUNTEER
  title        String
  organization String
  description  String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("experiences")
}

model Application {
  id          String   @id @default(cuid())
  listingId   String
  applicantId String
  ownerId     String
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant   User     @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  owner       User     @relation("ListingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([listingId, applicantId])
  @@index([ownerId])
  @@index([applicantId])
  @@map("applications")
}

model SavedListing {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@unique([userId, listingId])
  @@map("saved_listings")
}
