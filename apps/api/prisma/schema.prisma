generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NOTE: SQLite does not support enums, using String fields instead ────────

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  password       String
  displayName    String
  avatarUrl      String?
  bio            String?
  phoneNumber    String?
  skills         String   @default("[]")       // JSON array of skill strings
  interests      String   @default("[]")       // JSON array of interest strings
  activityPoints Int      @default(0)
  role           String   @default("USER")     // USER | MODERATOR | ADMIN
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  listings            Listing[]
  communities          CommunityMember[]
  ownedCommunities     Community[]         @relation("CommunityOwner")
  forumTopics          ForumTopic[]
  forumComments        ForumComment[]
  userBadges           UserBadge[]
  experiences          Experience[]
  sentMessages         ChatMessage[]
  conversations        ConversationParticipant[]
  givenVotes           ForumVote[]
  applications         Application[]  @relation("Applicant")
  receivedApps         Application[]  @relation("ListingOwner")
  savedListings        SavedListing[]
  announcements        Announcement[]
  sentInvitations      Invitation[]   @relation("InvitationSender")
  receivedInvitations  Invitation[]   @relation("InvitationReceiver")
  eventParticipations  EventParticipation[]
  channelMessages      ChannelMessage[]

  @@map("users")
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("OTHER")    // VOLUNTEER | EDUCATION | JOBS | SERVICES | EVENTS | OTHER
  status      String   @default("ACTIVE")   // ACTIVE | CLOSED | DRAFT
  images      String   @default("[]")
  tags        String   @default("[]")
  viewCount   Int      @default(0)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
  savedBy      SavedListing[]

  @@index([category, status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([authorId])
  @@map("listings")
}

// ─── Community (İcma) System ─────────────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  type        String   @default("TECH")      // TECH | EDUCATION | NONPROFIT | BUSINESS | OTHER
  privacy     String   @default("PUBLIC")    // PUBLIC | PRIVATE | INVITE_ONLY
  coverUrl    String?
  avatarUrl   String?
  tags        String   @default("[]")
  settings    String   @default("{}")        // JSON settings object
  ownerId     String
  owner       User     @relation("CommunityOwner", fields: [ownerId], references: [id])
  members     CommunityMember[]
  announcements Announcement[]
  events      Event[]
  channels    Channel[]
  invitations Invitation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("communities")
}

model CommunityMember {
  userId      String
  communityId String
  role        String   @default("MEMBER")    // OWNER | ADMIN | MODERATOR | MEMBER
  joinedAt    DateTime @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@id([userId, communityId])
  @@map("community_members")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  isPinned    Boolean   @default(false)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([communityId])
  @@map("announcements")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  maxAttendees Int?
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  participants EventParticipation[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([communityId])
  @@map("events")
}

model EventParticipation {
  id       String   @id @default(cuid())
  userId   String
  eventId  String
  status   String   @default("REGISTERED")  // REGISTERED | ATTENDED | CANCELLED
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("event_participations")
}

model Invitation {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User      @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  message     String?
  channel     String    @default("PLATFORM")  // PLATFORM | EMAIL | SMS
  status      String    @default("PENDING")   // PENDING | ACCEPTED | REJECTED | EXPIRED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([communityId, receiverId])
  @@index([receiverId])
  @@map("invitations")
}

// ─── Discord-style Channel System ────────────────────────────────────────────

model Channel {
  id          String    @id @default(cuid())
  name        String
  slug        String
  description String?
  type        String    @default("TEXT")      // TEXT | EVENT | ANNOUNCEMENT
  category    String?                          // Channel category grouping
  isDefault   Boolean   @default(false)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages    ChannelMessage[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([communityId, slug])
  @@index([communityId])
  @@map("channels")
}

model ChannelMessage {
  id        String   @id @default(cuid())
  body      String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@map("channel_messages")
}

// ─── Forum ───────────────────────────────────────────────────────────────────

model ForumTopic {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  body         String
  tags         String         @default("[]")
  isPinned     Boolean        @default(false)
  isLocked     Boolean        @default(false)
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     ForumComment[]
  votes        ForumVote[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tags])
  @@index([isPinned, createdAt])
  @@index([createdAt])
  @@index([authorId])
  @@map("forum_topics")
}

model ForumComment {
  id        String         @id @default(cuid())
  body      String
  topicId   String
  topic     ForumTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ForumComment?  @relation("Replies", fields: [parentId], references: [id])
  replies   ForumComment[] @relation("Replies")
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes     ForumVote[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([topicId, createdAt])
  @@map("forum_comments")
}

model ForumVote {
  id        String        @id @default(cuid())
  value     Int           // 1 or -1
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId   String?
  topic     ForumTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  commentId String?
  comment   ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, topicId])
  @@unique([userId, commentId])
  @@map("forum_votes")
}

// ─── Direct Messaging ────────────────────────────────────────────────────────

model Conversation {
  id           String                   @id @default(cuid())
  participants ConversationParticipant[]
  messages     ChatMessage[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@map("conversations")
}

model ConversationParticipant {
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@id([userId, conversationId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String       @id @default(cuid())
  body           String
  isRead         Boolean      @default(false)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// ─── Badges & Experience ─────────────────────────────────────────────────────

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String
  tier        String      @default("BRONZE")  // BRONZE | SILVER | GOLD | PLATINUM
  userBadges  UserBadge[]
  createdAt   DateTime    @default(now())

  @@map("badges")
}

model UserBadge {
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@id([userId, badgeId])
  @@map("user_badges")
}

model Experience {
  id           String    @id @default(cuid())
  type         String    @default("WORK")  // WORK | EDUCATION | VOLUNTEER
  title        String
  organization String
  description  String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("experiences")
}

// ─── Applications & Saved ────────────────────────────────────────────────────

model Application {
  id          String   @id @default(cuid())
  listingId   String
  applicantId String
  ownerId     String
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant   User     @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  owner       User     @relation("ListingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([listingId, applicantId])
  @@index([ownerId])
  @@index([applicantId])
  @@map("applications")
}

model SavedListing {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@unique([userId, listingId])
  @@map("saved_listings")
}
